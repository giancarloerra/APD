# === Redis (required — used for FOVs, favorites, API key storage, location) ===
# Free tier available at https://upstash.com
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# === Auth (optional — if unset or empty, all routes are open; set for online deployment) ===
MASTER_PASSWORD=your-secret-password
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=random-64-char-hex-string

# === API Keys (optional — can also be set at runtime via Settings UI) ===
# Meteoblue: https://content.meteoblue.com/en/business-solutions/weather-apis/free-weather-api
METEOBLUE_API_KEY=your-meteoblue-key
# Telescopius: https://api.telescopius.com
TELESCOPIUS_API_KEY=your-telescopius-key

# === Observer Location (defaults, overridden by Redis if set via Settings) ===
OBSERVER_LAT=52.6278
OBSERVER_LON=-1.2983
OBSERVER_ALT=25

# === Production settings ===
# NODE_ENV=production
# Set this (or set it in your hosting dashboard) on any public-facing deployment.
# Enables HTTPS redirect and marks session cookies as secure (https-only).
# On cloud platforms (Render, Railway, etc.) set env vars in the dashboard —
# the server loads this .env file automatically when present.

# CORS_ORIGIN is NOT needed for most deployments.
# The frontend and API are served from the same URL in a standard Render/Railway deploy,
# so there is no cross-origin request and this setting has no effect.
# Only set it if you are hosting the frontend on a different domain than the API.
# CORS_ORIGIN=https://apd.yourdomain.com
